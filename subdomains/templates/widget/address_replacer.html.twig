{# Invisible widget: injects JS to replace server IPs with subdomain addresses #}
{% if subdomainMap is not empty %}
<script>
(function() {
    var subdomainMap = {{ subdomainMap|json_encode|raw }};

    function replaceAddresses() {
        // Find all elements with data-ip attribute
        document.querySelectorAll('[data-ip]').forEach(function(el) {
            var currentText = el.textContent.trim();
            if (!currentText || currentText === '' || el.classList.contains('placeholder')) return;

            // Try to match by finding the server card context
            // The IP:port text tells us which server this belongs to
            for (var serverId in subdomainMap) {
                var address = subdomainMap[serverId];
                // Check if the element's closest server card contains this server's data
                var card = el.closest('[data-server-id]');
                if (card && card.getAttribute('data-server-id') == serverId) {
                    el.textContent = address;
                    el.setAttribute('data-original-ip', currentText);
                    break;
                }
            }
        });

        // Also try matching by IP text content (fallback for pages without data-server-id)
        document.querySelectorAll('[data-ip]').forEach(function(el) {
            if (el.getAttribute('data-original-ip')) return; // Already replaced
            var currentText = el.textContent.trim();
            if (!currentText || currentText === '' || el.classList.contains('placeholder')) return;

            // Extract IP from text (could be ip:port)
            var ip = currentText.split(':')[0];
            for (var serverId in subdomainMap) {
                // We can't match by IP alone if multiple servers share IPs
                // but it's a reasonable fallback for single-server users
                if (Object.keys(subdomainMap).length === 1) {
                    el.textContent = subdomainMap[serverId];
                    el.setAttribute('data-original-ip', currentText);
                    break;
                }
            }
        });
    }

    // Run after PteroCA fills the data-ip elements (they start as placeholders)
    // Use MutationObserver to detect when placeholders are replaced with actual IPs
    var observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.type === 'characterData' || mutation.type === 'childList') {
                var target = mutation.target.nodeType === 3 ? mutation.target.parentElement : mutation.target;
                if (target && target.hasAttribute && target.hasAttribute('data-ip')) {
                    setTimeout(replaceAddresses, 100);
                }
            }
        });
    });

    // Observe the entire content area for changes
    var content = document.querySelector('.content-wrapper') || document.querySelector('main') || document.body;
    observer.observe(content, { childList: true, subtree: true, characterData: true });

    // Also run on DOMContentLoaded and after a delay (fallback)
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { setTimeout(replaceAddresses, 1000); });
    } else {
        setTimeout(replaceAddresses, 1000);
    }
    setTimeout(replaceAddresses, 3000); // Extra fallback
})();
</script>
{% endif %}

{% block main %}
    <div class="tab-pane" id="subdomain">
        <div class="row pt-3">
            <div class="col-12">
                <div id="subdomain-tab-content">
                    <div class="text-center py-5">
                        <i class="fas fa-spinner fa-spin fa-2x"></i>
                        <p class="mt-2 text-muted">Cargando...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
    (function() {
        var container = document.getElementById('subdomain-tab-content');
        var serverId = {{ server.id }};

        // Replace IP address in console stats with subdomain if available
        function replaceAddressDisplay(subdomainAddress) {
            if (!subdomainAddress) return;
            var ipEl = document.querySelector('[data-ip]');
            if (ipEl) {
                ipEl.textContent = subdomainAddress;
                ipEl.setAttribute('data-original-ip', ipEl.textContent);
            }
            // Also update the copy button if it exists
            var copyBtn = ipEl ? ipEl.parentElement.querySelector('button[onclick]') : null;
            if (copyBtn) {
                copyBtn.setAttribute('onclick', "navigator.clipboard.writeText('" + subdomainAddress + "')");
            }
        }

        // Load immediately on render
        fetch('/plugins/subdomains/servers/' + serverId + '/subdomain', {
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            credentials: 'same-origin'
        })
        .then(function(response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.text();
        })
        .then(function(html) {
            container.innerHTML = html;
            // Replace IP with subdomain in console stats
            var dataEl = container.querySelector('#subdomain-data');
            if (dataEl) {
                replaceAddressDisplay(dataEl.getAttribute('data-address'));
            }
            initSubdomainScripts();
        })
        .catch(function(err) {
            container.innerHTML = '<div class="alert alert-danger">'
                + '<i class="fas fa-exclamation-triangle"></i> Error loading subdomain manager. '
                + '<a href="/plugins/subdomains/servers/' + serverId + '/subdomain" class="alert-link">Open in new page</a>'
                + '</div>';
        });

        function initSubdomainScripts() {
            var checkUrl = '/plugins/subdomains/api/check-availability';
            var inputs = container.querySelectorAll('[data-subdomain-input]');

            inputs.forEach(function(input) {
                var timer;
                var resultEl = input.parentElement.querySelector('[data-availability-result]');
                var domainSelect = input.closest('form').querySelector('[data-domain-select]');
                var previewEl = input.closest('form').querySelector('[data-preview]');
                var previewAddr = input.closest('form').querySelector('[data-preview-address]');

                input.addEventListener('input', function() {
                    clearTimeout(timer);
                    var val = input.value.trim().toLowerCase();

                    if (previewEl && previewAddr && domainSelect) {
                        if (val.length > 0) {
                            previewEl.style.display = '';
                            previewAddr.textContent = val + '.' + domainSelect.options[domainSelect.selectedIndex].text.replace(/^\./, '');
                        } else {
                            previewEl.style.display = 'none';
                        }
                    }

                    if (val.length < 3) {
                        if (resultEl) resultEl.innerHTML = '';
                        return;
                    }

                    timer = setTimeout(function() {
                        var domainId = domainSelect ? domainSelect.value : '';
                        var formData = new FormData();
                        formData.append('subdomain', val);
                        formData.append('domain_id', domainId);

                        fetch(checkUrl, { method: 'POST', body: formData, credentials: 'same-origin' })
                        .then(function(r) { return r.json(); })
                        .then(function(data) {
                            if (resultEl) {
                                var escaped = data.message.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
                                resultEl.innerHTML = data.available
                                    ? '<span class="text-success"><i class="fas fa-check-circle"></i> ' + escaped + '</span>'
                                    : '<span class="text-danger"><i class="fas fa-times-circle"></i> ' + escaped + '</span>';
                            }
                        });
                    }, 500);
                });

                if (domainSelect) {
                    domainSelect.addEventListener('change', function() {
                        input.dispatchEvent(new Event('input'));
                    });
                }
            });

            var copyBtn = container.querySelector('[data-copy-address]');
            if (copyBtn) {
                copyBtn.addEventListener('click', function() {
                    var addr = copyBtn.getAttribute('data-copy-address');
                    navigator.clipboard.writeText(addr).then(function() {
                        var original = copyBtn.innerHTML;
                        copyBtn.innerHTML = '<i class="fas fa-check"></i> Copied!';
                        setTimeout(function() { copyBtn.innerHTML = original; }, 2000);
                    });
                });
            }
        }
    })();
    </script>
{% endblock %}

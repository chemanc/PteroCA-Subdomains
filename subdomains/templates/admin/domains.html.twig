{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_header_wrapper %}
    <div class="dashboard-header rounded-3 p-4 mb-4 mt-4">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-info rounded-circle me-3">
                        <i class="fas fa-server p-3 text-white"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold">{{ 'admin.domain_management'|trans({}, 'plugin_subdomains') }}</h4>
                        <p class="text-muted mb-0">
                            <a href="{{ ea_url().setController('Plugins\\Subdomains\\Controller\\Admin\\SubdomainCrudController').setAction('index') }}" class="text-info">
                                &larr; {{ 'admin.back_to_dashboard'|trans({}, 'plugin_subdomains') }}
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block main %}
    {# Existing Domains #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header">
            <h6 class="m-0 fw-bold text-info">{{ 'admin.configured_domains'|trans({}, 'plugin_subdomains') }}</h6>
        </div>
        <div class="card-body p-0">
            {% if domains is empty %}
                <p class="text-muted text-center py-4">{{ 'admin.no_domains'|trans({}, 'plugin_subdomains') }}</p>
            {% else %}
                <table class="table table-striped datagrid mb-0">
                    <thead><tr>
                        <th>{{ 'general.domain'|trans({}, 'plugin_subdomains') }}</th>
                        <th>Zone ID</th>
                        <th>Default</th>
                        <th>{{ 'general.status'|trans({}, 'plugin_subdomains') }}</th>
                        <th>{{ 'general.actions'|trans({}, 'plugin_subdomains') }}</th>
                    </tr></thead>
                    <tbody>
                    {% for domain in domains %}
                        <tr>
                            <td><strong>{{ domain.domain }}</strong></td>
                            <td><code class="text-info">{{ domain.cloudflareZoneId }}</code></td>
                            <td>{% if domain.isDefault %}<span class="badge bg-primary">Yes</span>{% else %}<span class="text-muted">No</span>{% endif %}</td>
                            <td>{% if domain.isActive %}<span class="badge bg-success">Active</span>{% else %}<span class="badge bg-secondary">Disabled</span>{% endif %}</td>
                            <td>
                                <form action="{{ path('plugin_subdomains_api_domains_delete', {id: domain.id}) }}" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this domain?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </div>

    {# Add Domain Form #}
    <div class="card border-0 shadow-sm rounded-3 mb-4">
        <div class="card-header">
            <h6 class="m-0 fw-bold text-info">{{ 'admin.add_domain'|trans({}, 'plugin_subdomains') }}</h6>
        </div>
        <div class="card-body">
            <form action="{{ path('plugin_subdomains_api_domains_add') }}" method="POST">
                <div class="row align-items-end">
                    <div class="col-md-4 mb-2">
                        <label class="form-label">{{ 'admin.domain_name'|trans({}, 'plugin_subdomains') }}</label>
                        <input type="text" class="form-control" name="domain" placeholder="example.com" required>
                    </div>
                    <div class="col-md-4 mb-2">
                        <label class="form-label">Cloudflare Zone ID</label>
                        <input type="text" class="form-control" name="cloudflare_zone_id" placeholder="Zone ID" required>
                    </div>
                    <div class="col-md-2 mb-2">
                        <div class="form-check mt-4">
                            <input type="checkbox" class="form-check-input" name="is_default" value="1">
                            <label class="form-check-label">Default</label>
                        </div>
                    </div>
                    <div class="col-md-2 mb-2">
                        <button type="submit" class="btn btn-success w-100">
                            <i class="fas fa-plus"></i> Add
                        </button>
                    </div>
                </div>
            </form>

            <hr>

            {# Test Connection #}
            <h6>{{ 'admin.test_connection'|trans({}, 'plugin_subdomains') }}</h6>
            <div class="row align-items-end">
                <div class="col-md-8 mb-2">
                    <input type="text" class="form-control" id="testZoneId" placeholder="Enter Zone ID to test">
                </div>
                <div class="col-md-4 mb-2">
                    <button type="button" class="btn btn-outline-info w-100" id="btnTestConnection">
                        <i class="fas fa-plug"></i> {{ 'admin.test_connection'|trans({}, 'plugin_subdomains') }}
                    </button>
                </div>
            </div>
            <div id="testResult" class="mt-2"></div>
        </div>
    </div>
{% endblock %}

{% block body_javascript %}
    {{ parent() }}
    <script>
    document.getElementById('btnTestConnection').addEventListener('click', function() {
        var btn = this;
        var zoneId = document.getElementById('testZoneId').value.trim();
        var resultDiv = document.getElementById('testResult');

        if (!zoneId) { resultDiv.innerHTML = '<span class="text-danger">Please enter a Zone ID.</span>'; return; }

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Testing...';
        resultDiv.innerHTML = '';

        fetch('{{ path("plugin_subdomains_api_test_connection") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'zone_id=' + encodeURIComponent(zoneId),
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            resultDiv.innerHTML = data.success
                ? '<span class="text-success"><i class="fas fa-check-circle"></i> ' + data.message + ' (Zone: ' + (data.data && data.data.zone_name ? data.data.zone_name : '') + ')</span>'
                : '<span class="text-danger"><i class="fas fa-times-circle"></i> ' + data.message + '</span>';
        })
        .catch(function() { resultDiv.innerHTML = '<span class="text-danger">Connection failed.</span>'; })
        .finally(function() { btn.disabled = false; btn.innerHTML = '<i class="fas fa-plug"></i> Test Connection'; });
    });
    </script>
{% endblock %}

{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_header_wrapper %}
    <div class="dashboard-header rounded-3 p-4 mb-4 mt-4">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-primary rounded-circle me-3">
                        <i class="fas fa-globe p-3 text-white"></i>
                    </div>
                    <div>
                        <h4 class="mb-1 fw-bold">{{ 'admin.title'|trans({}, 'plugin_subdomains') }}</h4>
                        <p class="text-muted mb-0">{{ 'admin.description'|trans({}, 'plugin_subdomains') }}</p>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a href="{{ ea_url().setController('Plugins\\Subdomains\\Controller\\Admin\\DomainCrudController').setAction('index') }}"
                       class="btn btn-outline-light btn-sm">
                        <i class="fas fa-server"></i> {{ 'admin.domains'|trans({}, 'plugin_subdomains') }}
                    </a>
                    <form action="{{ path('plugin_subdomains_api_sync') }}" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-outline-light btn-sm" onclick="return confirm('Sync all DNS records?')">
                            <i class="fas fa-sync"></i> {{ 'admin.sync_dns'|trans({}, 'plugin_subdomains') }}
                        </button>
                    </form>
                    <a href="{{ path('plugin_subdomains_api_export') }}" class="btn btn-outline-light btn-sm">
                        <i class="fas fa-download"></i> {{ 'admin.export'|trans({}, 'plugin_subdomains') }}
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block main %}
    {# Stats Cards #}
    <div class="row mb-4">
        {% set cards = [
            {label: 'admin.total_subdomains', value: stats.total, color: 'primary', icon: 'globe'},
            {label: 'admin.active_subdomains', value: stats.active, color: 'success', icon: 'check-circle'},
            {label: 'admin.suspended', value: stats.suspended, color: 'warning', icon: 'pause-circle'},
            {label: 'admin.errors', value: stats.error, color: 'danger', icon: 'exclamation-triangle'}
        ] %}
        {% for card in cards %}
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="card border-{{ card.color }} border-start border-4 h-100">
                <div class="card-body">
                    <div class="small fw-bold text-{{ card.color }} text-uppercase mb-1">{{ card.label|trans({}, 'plugin_subdomains') }}</div>
                    <div class="h4 mb-0 fw-bold">{{ card.value }}</div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    {# Secondary stats #}
    <div class="row mb-4">
        {% set timeCards = [
            {key: 'today', value: stats.today},
            {key: 'this_week', value: stats.this_week},
            {key: 'this_month', value: stats.this_month}
        ] %}
        {% for tc in timeCards %}
        <div class="col-md-4 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <div class="small fw-bold text-info text-uppercase mb-1">{{ ('admin.created_' ~ tc.key)|trans({}, 'plugin_subdomains') }}</div>
                    <div class="h4 mb-0 fw-bold">{{ tc.value }}</div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <div class="row">
        {# Recent Subdomains #}
        <div class="col-lg-8 mb-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="m-0 fw-bold text-info">{{ 'admin.recent_subdomains'|trans({}, 'plugin_subdomains') }}</h6>
                </div>
                <div class="card-body p-0">
                    {% if recentSubdomains is empty %}
                        <p class="text-muted text-center py-4">{{ 'general.no_results'|trans({}, 'plugin_subdomains') }}</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-striped datagrid mb-0">
                                <thead><tr>
                                    <th>{{ 'general.subdomain'|trans({}, 'plugin_subdomains') }}</th>
                                    <th>{{ 'general.domain'|trans({}, 'plugin_subdomains') }}</th>
                                    <th>Server</th>
                                    <th>{{ 'general.status'|trans({}, 'plugin_subdomains') }}</th>
                                    <th>{{ 'general.created'|trans({}, 'plugin_subdomains') }}</th>
                                </tr></thead>
                                <tbody>
                                {% for sub in recentSubdomains %}
                                    <tr>
                                        <td><strong>{{ sub.subdomain }}</strong></td>
                                        <td>{{ sub.domain.domain }}</td>
                                        <td>#{{ sub.serverId }}</td>
                                        <td>
                                            {% if sub.status == 'active' %}
                                                <span class="badge bg-success">{{ 'status.active'|trans({}, 'plugin_subdomains') }}</span>
                                            {% elseif sub.status == 'pending' %}
                                                <span class="badge bg-warning text-dark">{{ 'status.pending'|trans({}, 'plugin_subdomains') }}</span>
                                            {% elseif sub.status == 'suspended' %}
                                                <span class="badge bg-secondary">{{ 'status.suspended'|trans({}, 'plugin_subdomains') }}</span>
                                            {% elseif sub.status == 'error' %}
                                                <span class="badge bg-danger" title="{{ sub.errorMessage }}">{{ 'status.error'|trans({}, 'plugin_subdomains') }}</span>
                                            {% endif %}
                                        </td>
                                        <td>{{ sub.createdAt|date('Y-m-d H:i') }}</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Sidebar #}
        <div class="col-lg-4 mb-4">
            {# Domains #}
            <div class="card mb-3">
                <div class="card-header">
                    <h6 class="m-0 fw-bold text-info">{{ 'admin.domains'|trans({}, 'plugin_subdomains') }}</h6>
                </div>
                <div class="card-body">
                    {% if domains is empty %}
                        <p class="text-muted text-center">{{ 'admin.no_domains'|trans({}, 'plugin_subdomains') }}</p>
                    {% else %}
                        <ul class="list-group list-group-flush">
                        {% for domain in domains %}
                            <li class="list-group-item d-flex justify-content-between">
                                <div>
                                    <strong>{{ domain.domain }}</strong>
                                    {% if domain.isDefault %}<span class="badge bg-primary ms-1">Default</span>{% endif %}
                                </div>
                            </li>
                        {% endfor %}
                        </ul>
                    {% endif %}
                    <a href="{{ ea_url().setController('Plugins\\Subdomains\\Controller\\Admin\\DomainCrudController').setAction('index') }}"
                       class="btn btn-sm btn-info w-100 mt-2">
                        <i class="fas fa-cog"></i> {{ 'admin.manage_domains'|trans({}, 'plugin_subdomains') }}
                    </a>
                </div>
            </div>

            {# Quick Actions #}
            <div class="card">
                <div class="card-header">
                    <h6 class="m-0 fw-bold text-info">{{ 'admin.quick_actions'|trans({}, 'plugin_subdomains') }}</h6>
                </div>
                <div class="card-body">
                    <form action="{{ path('plugin_subdomains_api_blacklist_load_defaults') }}" method="POST" class="mb-2">
                        <button type="submit" class="btn btn-outline-warning btn-sm w-100" onclick="return confirm('Load default blacklist?')">
                            <i class="fas fa-ban"></i> {{ 'admin.load_default_blacklist'|trans({}, 'plugin_subdomains') }}
                        </button>
                    </form>
                    <form action="{{ path('plugin_subdomains_api_logs_clear') }}" method="POST">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100" onclick="return confirm('Clear all activity logs?')">
                            <i class="fas fa-trash"></i> {{ 'admin.clear_logs'|trans({}, 'plugin_subdomains') }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {% include '@PluginSubdomains/components/footer.html.twig' %}
{% endblock %}
